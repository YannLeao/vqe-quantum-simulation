	file = {/Users/fabio/Library/CloudStorage/GoogleDrive-fabio.nsantos@gmail.com/Meu Drive/Zotero/storage/DTNWGT5L/Bauer et al. - 2020 - Quantum algorithms for quantum chemistry and quantum materials science.pdf;/Users/fabio/Library/CloudStorage/GoogleDrive-fabio.nsantos@gmail.com/Meu Drive/Zotero/storage/9W8A4EA7/2001.html},
	issn = {0009-2665, 1520-6890},
	journaltitle = {Chemical Reviews},
	keywords = {Condensed Matter - Other Condensed Matter,Physics - Chemical Physics,Quantum Physics},
	number = {22},
	pages = {12685--12717},
	shortjournal = {Chem. Rev.},
	title = {Quantum Algorithms for Quantum Chemistry and Quantum Materials Science},
