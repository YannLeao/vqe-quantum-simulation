	issn = {0026-8976, 1362-3028},
	journaltitle = {Molecular Physics},
	keywords = {Physics - Chemical Physics,Quantum Physics},
	number = {5},
	pages = {735--750},
	shortjournal = {Molecular Physics},
	title = {Simulation of {{Electronic Structure Hamiltonians Using Quantum Computers}}},
