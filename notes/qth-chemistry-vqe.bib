	eprint = {1812.09976},
	eprintclass = {quant-ph},
	eprinttype = {arXiv},
	file = {/Users/fabio/Library/CloudStorage/GoogleDrive-fabio.nsantos@gmail.com/Meu Drive/Zotero/storage/WJDSM7MR/Cao et al. - 2018 - Quantum Chemistry in the Age of Quantum Computing.pdf;/Users/fabio/Library/CloudStorage/GoogleDrive-fabio.nsantos@gmail.com/Meu Drive/Zotero/storage/QRC3QC3D/1812.html},
	keywords = {Quantum Physics},
	pubstate = {prepublished},
	title = {Quantum {{Chemistry}} in the {{Age}} of {{Quantum Computing}}},
